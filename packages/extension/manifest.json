{
  "manifest_version": 3,
  "name": "CHAOS - Chrome Agent OS",
  "version": "0.1.41",
  "description": "Multiple personal AI agents that live in your browser, learn about you, and act on your behalf.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "contextMenus",
    "offscreen"
  ],
  "optional_permissions": [
    "tabs",
    "bookmarks",
    "history",
    "scripting",
    "notifications",
    "downloads",
    "readingList",
    "idle",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Open CHAOS"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Open CHAOS agent manager"
    },
    "activate-voice": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Activate voice input for current agent"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/voice/recognition-frame.html",
        "src/voice/recognition-frame.js",
        "src/voice/beep.wav",
        "src/voice/boop.wav"
      ]
    }
  ],
  "omnibox": {
    "keyword": "chaos"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "version_name": "0.1.41 (20e2bd1)"
}
