{
  "manifest_version": 3,
  "name": "CHAOS - Chrome Agent OS",
  "version": "0.0.1",
  "description": "Multiple personal AI agents that live in your browser, learn about you, and act on your behalf.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "contextMenus"
  ],
  "optional_permissions": [
    "tabs",
    "bookmarks",
    "history",
    "scripting",
    "notifications"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "app.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CHAOS"
  },
  "commands": {
    "activate-voice": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Activate voice input for current agent"
    }
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": [
        "src/voice/recognition-frame.html",
        "src/voice/recognition-frame.js"
      ]
    }
  ],
  "icons": {}
}
