{
  "manifest_version": 3,
  "name": "CHAOS - Chrome Agent OS",
  "version": "0.0.1",
  "description": "Multiple personal AI agents that live in your browser, learn about you, and act on your behalf.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "contextMenus",
    "offscreen"
  ],
  "optional_permissions": [
    "tabs",
    "bookmarks",
    "history",
    "scripting"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "app.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CHAOS"
  },
  "icons": {}
}
